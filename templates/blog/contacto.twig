{% extends 'layouts/base-home.twig' %}

{% block title %}Iniciar sesión{% endblock %}

{% block Carousel %}

            <!-- Header Start -->
            <div class="container-fluid bg-breadcrumb">
                <div class="container text-center py-5" style="max-width: 900px;">
                    <h4 class="text-white display-4 mb-4 wow fadeInDown" data-wow-delay="0.1s">Contacto</h4>
                    <ol class="breadcrumb d-flex justify-content-center mb-0 wow fadeInDown" data-wow-delay="0.3s">
                        <li class="breadcrumb-item"><a href="{{ url_for('home') }}">Inicio</a></li>
                        <li class="breadcrumb-item active text-primary">Contacto</li>
                    </ol>    
                </div>
            </div>
            <!-- Header End -->

{% endblock %}

{% block content %}
       
        <!-- Contact Start -->
        <div id="contacto" class="container-fluid contact bg-light py-5">
            <div class="container py-5">
                <div class="row g-5">
                    <div class="col-lg-6 h-100 wow fadeInUp" data-wow-delay="0.2s">
                        <div class="text-center mx-auto pb-5" style="max-width: 800px;">
                            <h4 class="text-uppercase text-primary">contáctanos</h4>
                            <h1 class="display-3 mb-3 text-secondary">Enviar Mensaje</h1>
                            <p class="mb-0">¿Quieres sumarte, proponer o contarnos algo? Escríbenos. Cada mensaje es parte de la construcción colectiva. Te responderemos lo antes posible. <a class="fw-bold" href="https://htmlcodex.com/contact-form"></a></p>
                        </div>
                        <form action="{{ url_for('procesaForm') }}" method="post">
                            <div class="row g-4">
                                <div class="col-lg-12 col-xl-6">
                                    <div class="form-floating">
                                        <input type="text" class="form-control border-0" id="nombre" name="nombre" placeholder="Su nombre">
                                        <label for="name">Nombre</label>
                                    </div>
                                </div>
                                <div class="col-lg-12 col-xl-6">
                                    <div class="form-floating">
                                        <input type="email" class="form-control border-0" id="email" name="email" placeholder="Su correo electrónico">
                                        <label for="email">Correo electrónico</label>
                                    </div>
                                </div>
                                <div class="col-lg-12 col-xl-6">
                                    <div class="form-floating">
                                        <input type="phone" class="form-control border-0" id="telefono" name="telefono" placeholder="Teléfono">
                                        <label for="phone">Número celular</label>
                                    </div>
                                </div>
                                <div class="col-lg-12 col-xl-6">
                                    <div class="form-floating">
                                        <input type="text" class="form-control border-0" id="asunto" name="asunto" placeholder="Tema">
                                        <label for="subject">Tema </label>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="form-floating">
                                        <textarea class="form-control border-0" placeholder="Deje su mensaje aquí" id="mensaje" name="mensaje"  style="height: 175px"></textarea>
                                        <label for="message">Mensaje</label>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <button class="btn btn-primary w-100 py-3">Enviar mensaje</button>
                                </div>
                                <input type="hidden" name="{{ csrf_name_key }}" value="{{ csrf_name }}">
                                <input type="hidden" name="{{ csrf_value_key }}" value="{{ csrf_value }}">
                            </div>
                        </form>
                    </div>
                    <div class="col-lg-6 wow fadeInUp" data-wow-delay="0.4s">
                        <div class="row g-4">
                            <div class="col-12">
                                <div class="d-inline-flex rounded bg-white w-100 p-4">
                                    <i class="fas fa-map-marker-alt fa-2x text-vino me-4"></i>
                                    <div>
                                        <h4>PT Estado de México</h4>
                                        <p class="mb-0">Lago Athabasca 103, Nueva Oxotitlán, C.P. 50100, Toluca de Lerdo, Estado de México.</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-12 col-xl-6">
                                <div class="d-inline-flex rounded bg-white w-100 p-4">
                                    <i class="fas fa-envelope fa-2x text-vino me-4"></i>
                                    <div>
                                        <h4>Correo electrónico</h4>
                                        <p class="mb-0">contacto@ptedomex.com.mx</p>
                                        <p class="mb-0">&nbsp;</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-12 col-xl-6">
                                <div class="d-inline-flex rounded bg-white w-100 p-4">
                                    <i class="fa fa-phone-alt fa-2x text-vino me-4"></i>
                                    <div>
                                        <h4>Teléfono</h4>
                                        <p class="mb-0">55 7155 4992</p>
                                        <p class="mb-0">55 7258 0337</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="h-100 overflow-hidden">
                                    <iframe src="https://www.google.com/maps/embed?pb=!4v1768421265300!6m8!1m7!1sPc-noc6D49RDjF_HWZYOtQ!2m2!1d19.27999772277519!2d-99.68336274788537!3f246.58678761976174!4f10.549948254823562!5f0.7820865974627469" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Contact End -->   

{% endblock %}
