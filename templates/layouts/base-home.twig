    {# Evento Modal Detail Listener #}
    <script>
      function showEventPopup(title, imgSrc, linkUrl, btnText) {
          const modalEl = document.getElementById('eventDetailModal');
          const modalTitle = document.getElementById('eventDetailTitle');
          const modalImg = document.getElementById('eventDetailImg');
          const modalLinkContainer = document.getElementById('eventDetailLinkContainer');
          const modalLink = document.getElementById('eventDetailLink');

          modalTitle.textContent = title;
          modalImg.src = imgSrc;
          modalImg.alt = title;

          if (linkUrl && linkUrl !== '') {
            modalLink.href = linkUrl;
            modalLink.textContent = btnText || 'Ver detalles';
            modalLinkContainer.classList.remove('d-none');
          } else {
            modalLinkContainer.classList.add('d-none');
          }

          const modal = new bootstrap.Modal(modalEl);
          
          // Ensure focus management: blur the document to avoid conflicts
          document.activeElement.blur(); 
          
          modal.show();
      }

      document.addEventListener('DOMContentLoaded', function() {
        const eventThumbnails = document.querySelectorAll('.event-thumb-container');
        console.log('Event listeners attached to', eventThumbnails.length, 'thumbnails');

        eventThumbnails.forEach(container => {
          container.addEventListener('click', function(e) {
            console.log('Thumbnail clicked!');
            const title = container.dataset.title;
            const imgSrc = container.dataset.imgSrc;
            const linkUrl = container.dataset.linkUrl;
            const btnText = container.dataset.btnText;

            showEventPopup(title, imgSrc, linkUrl, btnText);
          });
        });
      });
    </script>

