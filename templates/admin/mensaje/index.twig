{% extends 'layouts/admin-base.twig' %}

{% block title %}Listado de Categorias{% endblock %}


{% block content %}
<div class="container mt-4">
  

     <div class="d-flex justify-content-between align-items-center mb-4">
        
    </div>
    <h1 class="h3 mb-2 text-gray-800">Listado de Mensajes</h1>
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="thead-dark">
                <tr>
                    <th>ID</th>
                    <th>Nombre</th>
                    <th>Email</th>
                    <th>Estado</th>
                    <th>Asunto</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for mensaje in mensajes %}
                <tr>
                    <td>{{ mensaje.id }}</td>
                    <td>{{ mensaje.nombre }}</td>
                    <td>{{ mensaje.email }}</td>
                    <td>{{ mensaje.estatus }}</td>
                    <td>{{ mensaje.asunto }}</td>
                    <td>
                        <div class="btn-group" role="group">
                            <a href="{{ url_for('mensaje.edit', {id: mensaje.id}) }}" class="btn btn-sm btn-primary">
                                <i class="fas fa-edit"></i> Cambiar Estado
                            </a>
                            <a href="{{ url_for('mensaje.view', {id: mensaje.id}) }}" class="btn btn-sm btn-secondary">
                                <i class="fas fa-eye"></i> Ver
                            </a>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

</div>


{% endblock %}