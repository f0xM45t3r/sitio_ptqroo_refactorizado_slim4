{% extends 'layouts/admin-base.twig' %}

{% block title %}Listado de Autores{% endblock %}

{% block content %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">Listado de Autores</h1>
        <a href="{{ url_for('autor.create') }}" class="btn btn-primary btn-icon-split shadow">
            <span class="icon text-white-50">
                <i class="fas fa-plus"></i>
            </span>
            <span class="text">Agregar Autor</span>
        </a>
    </div>

    <div class="card shadow mb-4">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover" id="dataTable" width="100%" cellspacing="0">
                    <thead class="thead-light">
                        <tr>
                            <th>ID</th>
                            <th>Foto</th>
                            <th>Nombre</th>
                            <th>Cargo</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for autor in autores %}
                        <tr>
                            <td>{{ autor.id }}</td>
                            <td class="text-center">
                                {% if autor.url_media %}
                                    {# Usamos un filtro de lowercase por si acaso hay conflicto de extensiones #}
                                    <a href="#" class="view-photo" data-photo="{{ base_url }}img/autores/{{ autor.url_media }}" data-name="{{ autor.display_name }}">
                                        <img class="img-profile rounded-circle border shadow-sm"
                                        src="{{ base_url }}img/autores/{{ autor.url_media }}" 
                                        style="width: 50px; height: 50px; object-fit: cover; cursor: pointer;"
                                        onerror="this.onerror=null; this.src='{{ base_url }}img/autores/sin.jpg';">
                                    </a>
                                {% else %}
                                    <div class="bg-light rounded-circle border d-inline-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                        <i class="fas fa-user text-gray-400"></i>
                                    </div>
                                {% endif %}
                            </td>
                            <td class="align-middle fw-bold">{{ autor.display_name }}</td>
                            <td class="align-middle">{{ autor.charge }}</td>
                            <td class="align-middle text-center">
                                <div class="dropdown no-arrow">
                                    <a class="dropdown-toggle btn btn-sm btn-light" href="#" role="button" id="dropdownMenuLink{{ autor.id }}" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                        <i class="fas fa-ellipsis-v fa-sm fa-fw text-gray-400"></i>
                                    </a>
                                    <div class="dropdown-menu dropdown-menu-right shadow animated--fade-in" aria-labelledby="dropdownMenuLink{{ autor.id }}">
                                        <div class="dropdown-header">Acciones:</div>
                                        <a class="dropdown-item" href="{{ url_for('autor.ponfoto', {id: autor.id}) }}">
                                            <i class="fas fa-camera fa-sm fa-fw mr-2 text-gray-400"></i> Poner foto
                                        </a>
                                        <a class="dropdown-item" href="{{ url_for('autor.edit', {id: autor.id}) }}">
                                            <i class="fas fa-edit fa-sm fa-fw mr-2 text-gray-400"></i> Editar
                                        </a>
                                        <div class="dropdown-divider"></div>
                                        <form action="{{ url_for('autor.delete', {id: autor.id}) }}" method="POST" class="d-inline">
                                            <input type="hidden" name="_METHOD" value="DELETE">
                                            <button type="submit" class="dropdown-item text-danger" onclick="return confirm('¿Eliminar este autor?')" {{ (autor.posts_count == 0)?'':'disabled' }}>
                                                <i class="fas fa-trash fa-sm fa-fw mr-2 text-danger"></i> Borrar
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Paginación -->
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            {% if autores.currentPage() > 1 %}
            <li class="page-item">
                <a class="page-link" href="{{ url_for('autor.index') }}?page={{ autores.currentPage() - 1 }}">Anterior</a>
            </li>
            {% endif %}

            {% for i in 1..autores.lastPage() %}
            <li class="page-item {{ i == autores.currentPage() ? 'active' : '' }}">
                <a class="page-link" href="{{ url_for('autor.index') }}?page={{ i }}">{{ i }}</a>
            </li>
            {% endfor %}

            {% if autores.currentPage() < autores.lastPage() %}
            <li class="page-item">
                <a class="page-link" href="{{ url_for('autor.index') }}?page={{ autores.currentPage() + 1 }}">Siguiente</a>
            </li>
            {% endif %}
        </ul>
    </nav>
</div>

<!-- Modal para ver foto -->
<div class="modal fade" id="photoModal" tabindex="-1" role="dialog" aria-labelledby="photoModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content shadow-lg border-0">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="photoModalLabel text-white">Foto del Autor</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body text-center p-0">
                <img id="modalPhotoImg" src="" class="img-fluid" style="width: 100%; height: auto;">
                <div class="p-3">
                    <h5 id="modalPhotoName" class="mb-0"></h5>
                </div>
            </div>
        </div>
    </div>
</div>

{% endblock %}

{% block script %}
<script>
$(document).ready(function() {
    $('.view-photo').on('click', function(e) {
        e.preventDefault();
        var photoUrl = $(this).data('photo');
        var name = $(this).data('name');
        
        $('#modalPhotoImg').attr('src', photoUrl);
        $('#modalPhotoName').text(name);
        $('#photoModalLabel').text('Foto de: ' + name);
        $('#photoModal').modal('show');
    });
});
</script>
<style>
    .fw-bold { font-weight: bold; }
    .table td { vertical-align: middle; }
    .dropdown-item[disabled] { pointer-events: none; opacity: 0.6; }
</style>
{% endblock %}
