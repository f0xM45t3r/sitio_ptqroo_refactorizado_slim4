{% extends 'layouts/admin-base.twig' %}

{% block title %}Listado de Autores{% endblock %}


{% block content %}
<div class="container mt-4">
  

     <div class="d-flex justify-content-between align-items-center mb-4">
        <a href="{{ url_for('autor.create') }}" class="btn btn-primary btn-lg rounded-circle shadow" title="Agregar Autor">
            <i class="fas fa-plus"></i>
        </a>
    </div>
    <h1 class="h3 mb-2 text-gray-800">Listado de Autores</h1>
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="thead-dark">
                <tr>
                    <th>ID</th>
                    <th>Foto</th>
                    <th>Nombre</th>
                    <th>Cargo</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for autor in autores %}
                <tr>
                    <td>{{ autor.id }}</td>
                    <td>
                        <img class="img-profile rounded-circle"
                        src="{{ base_url }}img/autores/{{autor.url_media}}" style="width: 60px; height: 60px; object-fit: cover;">
                    </td>
                    <td>{{ autor.display_name }}</td>
                    <td>{{ autor.charge }}</td>
                    <td>
                        <div class="btn-group" role="group">
                            <a href="{{ url_for('autor.ponfoto', {id: autor.id}) }}" class="btn btn-sm btn-secondary">
                                <i class="fas fa-camera"></i> Poner foto
                            </a>
                            <a href="{{ url_for('autor.edit', {id: autor.id}) }}" class="btn btn-sm btn-primary">
                                <i class="fas fa-edit"></i> Editar
                            </a>
                            <form action="{{ url_for('autor.delete', {id: autor.id}) }}" method="autor" class="d-inline">
                                <input type="hidden" name="_METHOD" value="DELETE">
                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('¿Eliminar este autor?')" {{ (autor.posts_count == 0)?'':'disabled' }} >
                                    <i class="fas fa-trash"></i> Borrar
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <!-- Paginación -->
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            {% if autores.currentPage() > 1 %}
            <li class="page-item">
                <a class="page-link" href="{{ url_for('autor.index') }}?page={{ autores.currentPage() - 1 }}" aria-label="Previous">
                    <span aria-hidden="true">&laquo;</span>
                </a>
            </li>
            {% endif %}

            {% for i in 1..autores.lastPage() %}
            <li class="page-item {{ i == autores.currentPage() ? 'active' : '' }}">
                <a class="page-link" href="{{ url_for('autor.index') }}?page={{ i }}">{{ i }}</a>
            </li>
            {% endfor %}

            {% if autores.currentPage() < autores.lastPage() %}
            <li class="page-item">
                <a class="page-link" href="{{ url_for('autor.index') }}?page={{ aautores.currentPage() + 1 }}" aria-label="Next">
                    <span aria-hidden="true">&raquo;</span>
                </a>
            </li>
            {% endif %}
        </ul>
    </nav>

</div>


{% endblock %}