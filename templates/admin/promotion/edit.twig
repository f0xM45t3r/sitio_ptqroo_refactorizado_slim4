{% extends 'layouts/admin-base.twig' %}

{% block title %}Editar Promoción/Evento{% endblock %}

{% block content %}
<div class="container mt-4">
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Editar: {{ promotion.title }}</h6>
        </div>
        <div class="card-body">
            <form action="{{ url_for('admin.promotions.update', {id: promotion.id}) }}" method="POST" enctype="multipart/form-data">
                <div class="row">
                    <div class="col-md-8">
                        <div class="form-group">
                            <label for="title">Título del Evento/Promoción</label>
                            <input type="text" name="title" id="title" class="form-control" required value="{{ promotion.title }}">
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="link_url">URL de Destino (Opcional)</label>
                                    <input type="url" name="link_url" id="link_url" class="form-control" value="{{ promotion.link_url }}">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="button_text">Texto del Botón</label>
                                    <input type="text" name="button_text" id="button_text" class="form-control" value="{{ promotion.button_text }}">
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="event_date">Fecha del Evento</label>
                                    <input type="datetime-local" name="event_date" id="event_date" class="form-control" value="{{ promotion.event_date ? promotion.event_date|date('Y-m-d\\TH:i') : '' }}">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="event_location">Ubicación</label>
                                    <input type="text" name="event_location" id="event_location" class="form-control" value="{{ promotion.event_location }}">
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4 text-center">
                        <div class="form-group">
                            <label>Imagen Actual</label><br>
                            {% if promotion.image_path %}
                                <img src="/img/promos/{{ promotion.image_path }}" class="img-fluid img-thumbnail mb-2" style="max-height: 200px;">
                            {% endif %}
                            <input type="file" name="image" id="image" class="form-control-file">
                        </div>
                        <hr>
                        <div class="form-group text-left">
                            <div class="custom-control custom-switch">
                                <input type="checkbox" name="is_active" class="custom-control-input" id="is_active" {{ promotion.is_active ? 'checked' : '' }}>
                                <label class="custom-control-label" for="is_active">¿Está activa?</label>
                            </div>
                        </div>
                        <div class="form-group text-left">
                            <label for="starts_at">Mostrar desde:</label>
                            <input type="datetime-local" name="starts_at" id="starts_at" class="form-control" value="{{ promotion.starts_at ? promotion.starts_at|date('Y-m-d\\TH:i') : '' }}">
                        </div>
                        <div class="form-group text-left">
                            <label for="ends_at">Ocultar automáticamente el:</label>
                            <input type="datetime-local" name="ends_at" id="ends_at" class="form-control" value="{{ promotion.ends_at ? promotion.ends_at|date('Y-m-d\\TH:i') : '' }}">
                        </div>
                    </div>
                </div>
                <hr>
                <div class="text-right">
                    <a href="{{ url_for('admin.promotions') }}" class="btn btn-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-primary">Actualizar Cambios</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
