{% extends 'layouts/admin-base.twig' %}

{% block title %}Crear Promoción/Evento{% endblock %}

{% block content %}
<div class="container mt-4">
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Nueva Promoción / Evento</h6>
        </div>
        <div class="card-body">
            <form action="{{ url_for('admin.promotions.store') }}" method="POST" enctype="multipart/form-data">
                <div class="row">
                    <div class="col-md-8">
                        <div class="form-group">
                            <label for="title">Título del Evento/Promoción</label>
                            <input type="text" name="title" id="title" class="form-control" required placeholder="Ej: Gran Mitin en Toluca">
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="link_url">URL de Destino (Opcional)</label>
                                    <input type="url" name="link_url" id="link_url" class="form-control" placeholder="https://...">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="button_text">Texto del Botón</label>
                                    <input type="text" name="button_text" id="button_text" class="form-control" placeholder="Ej: Registrarme, Ver más...">
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="event_date">Fecha del Evento</label>
                                    <input type="datetime-local" name="event_date" id="event_date" class="form-control">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="event_location">Ubicación</label>
                                    <input type="text" name="event_location" id="event_location" class="form-control" placeholder="Ej: Plaza de los Mártires">
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="image">Imagen del Evento (Pop-up)</label>
                            <input type="file" name="image" id="image" class="form-control-file" required>
                            <small class="form-text text-muted">Formatos sugeridos: JPG, PNG. Se recomienda formato vertical para pop-ups.</small>
                        </div>
                        <hr>
                        <div class="form-group">
                            <div class="custom-control custom-switch">
                                <input type="checkbox" name="is_active" class="custom-control-input" id="is_active" checked>
                                <label class="custom-control-label" for="is_active">¿Está activa?</label>
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="starts_at">Mostrar desde:</label>
                            <input type="datetime-local" name="starts_at" id="starts_at" class="form-control">
                        </div>
                        <div class="form-group">
                            <label for="ends_at">Ocultar automáticamente el:</label>
                            <input type="datetime-local" name="ends_at" id="ends_at" class="form-control">
                        </div>
                    </div>
                </div>
                <hr>
                <div class="text-right">
                    <a href="{{ url_for('admin.promotions') }}" class="btn btn-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-primary">Guardar Promoción</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
