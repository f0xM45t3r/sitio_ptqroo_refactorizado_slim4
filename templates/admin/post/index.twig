{% extends 'layouts/admin-base.twig' %}

{% block title %}Iniciar sesión{% endblock %}


{% block content %}

  
<div class="container mt-1">

     <div class="d-flex justify-content-between align-items-center mb-4">
        <a href="{{ url_for('post.create') }}" class="btn btn-primary btn-lg rounded-circle shadow" title="Nuevo Post">
            <i class="fas fa-plus"></i>
        </a>
        
        <form action="{{ url_for('post.index') }}" method="GET" class="form-inline d-flex align-items-center">
            <label class="mr-2 font-weight-bold mb-0">Filtrar por:</label>
            <select name="category_id" class="form-control form-control-sm mx-2" onchange="this.form.submit()">
                <option value="">Todas las categorías</option>
                {% for category in categories %}
                <option value="{{ category.id }}" {{ current_category == category.id ? 'selected' : '' }}>
                    {{ category.name }}
                </option>
                {% endfor %}
            </select>
            {% if current_category %}
                <a href="{{ url_for('post.index') }}" class="btn btn-sm btn-outline-secondary">Limpiar</a>
            {% endif %}
        </form>
    </div>

    <h1 class="h3 mb-2 text-gray-800">Listado de Publicaciones</h1>
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="thead-dark">
                <tr>
                    <th>ID</th>
                    <th>Título</th>
                    <th>Categoría</th>
                    <th>Imagen</th>
                    <th>Creado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for post in posts %}
                <tr>
                    <td>{{ post.id }}</td>
                    <td>{{ post.title }}</td>
                    <td>
                        <span class="badge badge-info">{{ post.category.name }}</span>
                    </td>
                    <td>
                        {% if post.url_media %}
                        <img src="/img/blog/{{ post.url_media }}" width="50" class="img-thumbnail">
                        {% else %}
                        Sin imagen
                        {% endif %}
                    </td>
                    <td>{{ post.published_at|date('d/m/Y H:i') }}</td>
                    <td>
                        <div class="btn-group" role="group">
                            <a href="{{ url_for('entrada', {slug: post.slug}) }}" class="btn btn-sm btn-primary" target="_blank" >
                                <i class="fas fa-eye"></i> Ver
                            </a>
                            <a href="{{ url_for('post.ponfoto', {id: post.id}) }}" class="btn btn-sm btn-secondary">
                                <i class="fas fa-camera"></i> Poner foto
                            </a>
                            <a href="{{ url_for('post.edit', {id: post.id}) }}" class="btn btn-sm btn-primary">
                                <i class="fas fa-edit"></i> Editar
                            </a>
                            <form action="{{ url_for('post.delete', {id: post.id}) }}" method="POST" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('¿Eliminar este post?')">
                                    <i class="fas fa-trash"></i> Borrar
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <!-- Paginación -->
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            {% if posts.currentPage() > 1 %}
            <li class="page-item">
                <a class="page-link" href="{{ url_for('post.index') }}?page={{ posts.currentPage() - 1 }}{{ current_category ? '&category_id=' ~ current_category : '' }}" aria-label="Previous">
                    <span aria-hidden="true">&laquo;</span>
                </a>
            </li>
            {% endif %}

            {% for i in 1..posts.lastPage() %}
            <li class="page-item {{ i == posts.currentPage() ? 'active' : '' }}">
                <a class="page-link" href="{{ url_for('post.index') }}?page={{ i }}{{ current_category ? '&category_id=' ~ current_category : '' }}">{{ i }}</a>
            </li>
            {% endfor %}

            {% if posts.currentPage() < posts.lastPage() %}
            <li class="page-item">
                <a class="page-link" href="{{ url_for('post.index') }}?page={{ posts.currentPage() + 1 }}{{ current_category ? '&category_id=' ~ current_category : '' }}" aria-label="Next">
                    <span aria-hidden="true">&raquo;</span>
                </a>
            </li>
            {% endif %}
        </ul>
    </nav>
</div>

{% endblock %}