{% extends 'layouts/admin-base.twig' %}

{% block title %}Iniciar sesión{% endblock %}


{% block content %}

  
<div class="container mt-1">

     <div class="d-flex justify-content-between align-items-center mb-4">
        <a href="{{ url_for('principal.create') }}" class="btn btn-primary btn-lg rounded-circle shadow" title="Nuevo Artículo Principal">
            <i class="fas fa-plus"></i>
        </a>
    </div>
    <h1 class="h3 mb-2 text-gray-800">Listado de Artículos Principales</h1>
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="thead-dark">
                <tr>
                    <th>ID</th>
                    <th>Imagen</th>
                    <th>Intro</th>
                    <th>Titulo</th>
                    
                    <th>Acciones</th>
                </tr>
            </thead>

            <tbody>
                {% for principal in principales %}
                <tr>
                    <td>{{ principal.id }}</td>
                     <td>   
                        {% if not principal.url_media %}
                            <i class="fa fa-eye-slash"></i>
                        {% else %}
                             <img src="/img/main/{{ principal.url_media }}" width="50" class="img-thumbnail">
                        {% endif %}
                    </td>
                    <td>{{ principal.intro }}</td>
                    <td>{{ principal.titulo }}</td>
                    
                    <td>
                        <div class="btn-group" role="group">
                           
                            <a href="{{ url_for('principal.ponfoto', {id: principal.id}) }}" class="btn btn-sm btn-secondary">
                                <i class="fas fa-camera"></i> Poner foto
                            </a>
                            <a href="{{ url_for('principal.edit', {id: principal.id}) }}" class="btn btn-sm btn-primary">
                                <i class="fas fa-edit"></i> Editar
                            </a>
                            <form action="{{ url_for('principal.delete', {id: principal.id}) }}" method="principal" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('¿Eliminar este artículo principal?')">
                                    <i class="fas fa-trash"></i> Borrar
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <!-- Paginación -->
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            {% if principales.currentPage() > 1 %}
            <li class="page-item">
                <a class="page-link" href="{{ url_for('principal.index') }}?page={{ principales.currentPage() - 1 }}" aria-label="Previous">
                    <span aria-hidden="true">&laquo;</span>
                </a>
            </li>
            {% endif %}

            {% for i in 1..principales.lastPage() %}
            <li class="page-item {{ i == principales.currentPage() ? 'active' : '' }}">
                <a class="page-link" href="{{ url_for('principal.index') }}?page={{ i }}">{{ i }}</a>
            </li>
            {% endfor %}

            {% if principales.currentPage() < principales.lastPage() %}
            <li class="page-item">
                <a class="page-link" href="{{ url_for('principal.index') }}?page={{ principales.currentPage() + 1 }}" aria-label="Next">
                    <span aria-hidden="true">&raquo;</span>
                </a>
            </li>
            {% endif %}
        </ul>
    </nav>
</div>

{% endblock %}