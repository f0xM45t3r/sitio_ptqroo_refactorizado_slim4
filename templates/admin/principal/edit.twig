{% extends 'layouts/admin-base.twig' %}

{% block title %}Crear Autor{% endblock %}

{% block content %}


    <div class="container mt-4">
        <h1>Editar Artículo Principal  -</h1>
        
        <form method="post" action="{{ url_for('principal.update',{'id':  principal.id }  ) }}">
            <div class="mb-3">
                <label for="nombre" class="form-label">Intro</label>
                <input type="text" class="form-control" id="intro" name="intro" value="{{principal.intro}}" required>
            </div>
                                  
            <div class="mb-3">
                <label for="cargo" class="form-label">titulo</label>
                <input type="text" class="form-control" id="titulo" name="titulo" value="{{principal.titulo}}" required>
            </div>

            <div class="mb-3">
                <label for="nombre" class="form-label">Balazo</label>
                <input type="text" class="form-control" id="balazo" name="balazo" value="{{principal.balazo}}" required>
            </div>
                                  
            <div class="mb-3">
                <label for="cargo" class="form-label">Id post</label>
                <input type="text" class="form-control" id="id_post" name="id_post" value="{{principal.id_post}}" required>
            </div>
            <div class="form-check">
                <input type="checkbox" class="form-check-input" id="publicar" name="publicar" value="y"  {{ principal.publicar == 'y' ? 'checked' : '' }} >
                <label class="form-check-label" for="publicar" >Publicar</label>
            </div>            
            <hr>
            <button type="submit" class="btn btn-primary">Actualizar </button>
            <a href="{{ url_for('principal.index') }}" class="btn btn-secondary">Cancelar</a>
        </form>
    </div>


{% endblock %}