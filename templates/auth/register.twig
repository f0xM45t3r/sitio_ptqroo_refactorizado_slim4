{% extends 'layouts/base.twig' %}

{% block title %}Registro {% endblock %}

{% block content %}
<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">Registro</div>

                <div class="card-body">
                    {% for message in flash.getMessages('error') %}
                        <div class="alert alert-danger">{{ message }}</div>
                    {% endfor %}
                    {% for message in flash.getMessages('success') %}
                        <div class="alert alert-success">{{ message }}</div>
                    {% endfor %}

                    <form method="POST" action="/auth/register">
                        <div class="form-group">
                            <label for="username">Nombre de usuario (opcional)</label>
                            <input id="username" type="text" class="form-control" name="username">
                        </div>

                        <div class="form-group">
                            <label for="email">Email</label>
                            <input id="email" type="email" class="form-control" name="email" required>
                        </div>

                        <div class="form-group">
                            <label for="password">Contraseña</label>
                            <input id="password" type="password" class="form-control" name="password" required minlength="8">
                            <small class="form-text text-muted">Mínimo 8 caracteres</small>
                        </div>

                        <div class="form-group mb-0">
                            <button type="submit" class="btn btn-primary">Registrarse</button>
                        </div>
                    </form>

                    <div class="mt-3 text-center">
                        <a href="/auth/login">¿Ya tienes cuenta? Inicia sesión</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}